# Production PocketBase server URL (required for GitHub Pages deployment)
# This URL is baked into the client bundle at build time — it is NOT a secret.
# When served from GitHub Pages, window.location.origin would be github.io, not PocketBase,
# so this MUST be set to the actual PocketBase server.
#
# UPDATE THIS to your real production PocketBase URL before deploying.
VITE_POCKETBASE_URL=https://urutau.fly.dev
